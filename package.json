    "react-hook-form": "7.72.0",
    "react-international-phone": "4.8.0",
    "react-toastify": "11.0.5",
    "socket.io": "4.8.3",
    "socket.io-client": "4.8.3",
    "tailwind-merge": "3.5.0",
